  m_Script: {fileID: 11500000, guid: 4e930a4696290904f90abe7711907f3f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DetailPanel
  title: {fileID: 193713936}
  description: {fileID: 1392120011}
  objectSetting:
  - name: 0
    title: "\uB85C\uBD07"
    description: "\uB85C\uBD07\uC740 \uC13C\uC11C\uC640 \uC81C\uC5B4 \uC2DC\uC2A4\uD15C\uC744
      \uD1B5\uD574 \uC8FC\uBCC0 \uD658\uACBD\uC744 \uC778\uC2DD\uD558\uACE0 \uB3D9\uC791\uD558\uB294
      \uC790\uB3D9\uD654 \uC7A5\uCE58\uC785\uB2C8\uB2E4.\r\n\r\n\uBCF8 \uC804\uC2DC\uC5D0\uC11C\uB294
      \uB85C\uBD07\uC758 \uAE30\uBCF8 \uAD6C\uC870\uC640 \uBBF8\uB798 \uAE30\uC220\uC774
      \uC0DD\uD65C\uACFC \uC0B0\uC5C5 \uC18D\uC5D0\uC11C \uC5B4\uB5BB\uAC8C \uD65C\uC6A9\uB420
      \uC218 \uC788\uB294\uC9C0 \uC0B4\uD3B4\uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    model: {fileID: 1358521789}
  - name: 1
    title: "\uC720\uBB3C"
    description: "\uC720\uBB3C\uC740 \uACFC\uAC70 \uC0AC\uB78C\uB4E4\uC774 \uB0A8\uAE34
      \uC0DD\uD65C\uACFC \uBB38\uD654\uC758 \uD754\uC801\uC744 \uBCF4\uC5EC\uC8FC\uB294
      \uC911\uC694\uD55C \uC790\uB8CC\uC785\uB2C8\uB2E4.\r\n\r\n\uBCF8 \uC804\uC2DC\uC5D0\uC11C\uB294
      \uACE0\uB300 \uC720\uBB3C\uC744 \uD1B5\uD574 \uB2F9\uC2DC\uC758 \uAE30\uC220,
      \uC608\uC220, \uC0C1\uC9D5\uC801 \uC758\uBBF8\uB97C \uC0B4\uD3B4\uBCFC \uC218
      \uC788\uC2B5\uB2C8\uB2E4."
    model: {fileID: 587202928}
  - name: 2
    title: "\uD589\uC131"
    description: "\uD589\uC131\uC740 \uC6B0\uC8FC \uACF5\uAC04\uC5D0\uC11C \uACE0\uC720\uD55C
      \uD615\uD0DC\uC640 \uD658\uACBD\uC744 \uAC00\uC9C4 \uCC9C\uCCB4\uC785\uB2C8\uB2E4.\r\n\r\n\uBCF8
      \uC804\uC2DC\uC5D0\uC11C\uB294 \uD589\uC131\uC758 \uAD6C\uC870\uC640 \uD2B9\uC9D5\uC744
      \uAD00\uCC30\uD558\uBA70 \uB2E4\uC591\uD55C \uCC9C\uCCB4\uC640 \uC6B0\uC8FC
      \uD658\uACBD\uC5D0 \uB300\uD55C \uC774\uD574\uB97C \uB113\uD790 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    model: {fileID: 1299370918}
  btnQuizPanel: {fileID: 454576593}
  QuizPanel: {fileID: 230051423}
