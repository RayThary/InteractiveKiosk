  m_Script: {fileID: 11500000, guid: b866359d41b141040be1e803e71a0551, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager
  correctQuizDatas:
  - showName: 0
    question: "\uB85C\uBD07\uC774 \uC804\uC2DC/\uC0B0\uC5C5 \uD604\uC7A5\uC5D0\uC11C
      \uD65C\uC6A9\uB418\uB294 \uAC00\uC7A5 \uD070 \uC774\uC720\uB294?"
    answerText: "\uBC18\uBCF5\uC801\uC774\uACE0 \uC815\uBC00\uD55C \uC791\uC5C5\uC744
      \uC548\uC815\uC801\uC73C\uB85C \uC218\uD589\uD560 \uC218 \uC788\uAE30 \uB54C\uBB38\uC785\uB2C8\uB2E4."
  - showName: 0
    question: "\uB85C\uBD07\uC774 \uC0AC\uB78C\uACFC \uD568\uAED8 \uC791\uC5C5\uD560
      \uB54C \uC911\uC694\uD55C \uC694\uC18C\uB294 \uBB34\uC5C7\uC778\uAC00\uC694?"
    answerText: "\uC8FC\uBCC0 \uD658\uACBD\uC744 \uAC10\uC9C0\uD558\uACE0 \uC548\uC804\uD558\uAC8C
      \uB3D9\uC791\uD558\uB294 \uAC83\uC785\uB2C8\uB2E4."
  - showName: 1
    question: "\uC720\uBB3C\uC744 \uC804\uC2DC\uD560 \uB54C \uAC00\uC7A5 \uC911\uC694\uD558\uAC8C
      \uC804\uB2EC\uD574\uC57C \uD558\uB294 \uC815\uBCF4\uB294 \uBB34\uC5C7\uC778\uAC00\uC694?"
    answerText: "\uC720\uBB3C\uC758 \uC2DC\uB300, \uC6A9\uB3C4, \uC5ED\uC0AC\uC801
      \uC758\uBBF8\uC785\uB2C8\uB2E4."
  - showName: 1
    question: "\uC720\uBB3C\uC774 \uACFC\uAC70 \uBB38\uD654\uB97C \uC774\uD574\uD558\uB294
      \uB370 \uB3C4\uC6C0\uC774 \uB418\uB294 \uC774\uC720\uB294 \uBB34\uC5C7\uC778\uAC00\uC694?"
    answerText: "\uB2F9\uC2DC \uC0AC\uB78C\uB4E4\uC758 \uC0DD\uD65C \uBC29\uC2DD\uACFC
      \uAE30\uC220 \uC218\uC900\uC744 \uBCF4\uC5EC\uC8FC\uAE30 \uB54C\uBB38\uC785\uB2C8\uB2E4."
  - showName: 2
    question: "\uD589\uC131\uC744 \uAD6C\uBD84\uD560 \uB54C \uC911\uC694\uD55C \uAE30\uC900\uC740
      \uBB34\uC5C7\uC778\uAC00\uC694?"
    answerText: "\uD06C\uAE30, \uADA4\uB3C4, \uAD6C\uC131 \uC131\uBD84 \uAC19\uC740
      \uD2B9\uC9D5\uC785\uB2C8\uB2E4."
  - showName: 2
    question: "\uD589\uC131\uC774 \uBCC4\uACFC \uB2E4\uB978 \uC810\uC740 \uBB34\uC5C7\uC778\uAC00\uC694?"
    answerText: "\uC2A4\uC2A4\uB85C \uBE5B\uC744 \uB0B4\uC9C0 \uC54A\uACE0 \uBCC4\uC758
      \uBE5B\uC744 \uBC18\uC0AC\uD55C\uB2E4\uB294 \uC810\uC785\uB2C8\uB2E4."
  wrongQuizDatas:
  - showName: 0
    answerText: "\uB85C\uBD07\uC774 \uC2A4\uC2A4\uB85C \uC7A0\uC744 \uC790\uAE30
      \uC704\uD574\uC11C\uC785\uB2C8\uB2E4."
    resultDescription: "\uB85C\uBD07\uC740 \uD734\uC2DD\uC744 \uC704\uD574 \uC874\uC7AC\uD558\uB294
      \uAC83\uC774 \uC544\uB2C8\uB77C, \uC0AC\uB78C\uC758 \uC791\uC5C5\uC744 \uBCF4\uC870\uD558\uAC70\uB098
      \uBC18\uBCF5 \uC791\uC5C5\uC744 \uC218\uD589\uD558\uAE30 \uC704\uD574 \uC0AC\uC6A9\uB429\uB2C8\uB2E4."
  - showName: 0
    answerText: "\uB85C\uBD07\uC774 \uC74C\uC2DD\uC744 \uBA39\uACE0 \uC5D0\uB108\uC9C0\uB97C
      \uC5BB\uAE30 \uC704\uD574\uC11C\uC785\uB2C8\uB2E4."
    resultDescription: "\uB85C\uBD07\uC740 \uC74C\uC2DD\uC774 \uC544\uB2C8\uB77C
      \uC804\uAE30, \uBC30\uD130\uB9AC, \uD504\uB85C\uADF8\uB7A8 \uC81C\uC5B4 \uB4F1\uC744
      \uD1B5\uD574 \uB3D9\uC791\uD569\uB2C8\uB2E4.."
  - showName: 0
    answerText: "\uB85C\uBD07\uC774 \uC804\uC2DC \uC124\uBA85\uC744 \uAC10\uC0C1\uD558\uAE30
      \uC704\uD574\uC11C\uC785\uB2C8\uB2E4."
    resultDescription: "\uB85C\uBD07\uC740 \uAD00\uB78C\uC790\uAC00 \uC544\uB2C8\uB77C,
      \uC815\uBCF4\uB97C \uC804\uB2EC\uD558\uAC70\uB098 \uB3D9\uC791\uC744 \uC218\uD589\uD558\uB294
      \uC7A5\uCE58\uB85C \uD65C\uC6A9\uB429\uB2C8\uB2E4."
  - showName: 1
    answerText: "\uC720\uBB3C\uC758 \uC0C9\uAE54\uC774 \uC608\uC058\uBA74 \uC5ED\uC0AC\uC801
      \uAC00\uCE58\uAC00 \uACB0\uC815\uB429\uB2C8\uB2E4."
    resultDescription: "\uC0C9\uC0C1\uB3C4 \uAD00\uB78C \uC694\uC18C\uAC00 \uB420
      \uC218 \uC788\uC9C0\uB9CC, \uC720\uBB3C\uC758 \uAC00\uCE58\uB294 \uC2DC\uB300\uC801
      \uBC30\uACBD\uACFC \uC0AC\uC6A9 \uBAA9\uC801, \uBCF4\uC874 \uC0C1\uD0DC \uB4F1
      \uB2E4\uC591\uD55C \uC694\uC18C\uB85C \uD310\uB2E8\uB429\uB2C8\uB2E4."
  - showName: 1
    answerText: "\uC624\uB798\uB41C \uBB3C\uAC74\uC740 \uBAA8\uB450 \uAC19\uC740
      \uC758\uBBF8\uB97C \uAC00\uC9D1\uB2C8\uB2E4."
    resultDescription: "\uC624\uB798\uB418\uC5C8\uB2E4\uACE0 \uD574\uC11C \uBAA8\uB450
      \uAC19\uC740 \uAC00\uCE58\uB97C \uAC00\uC9C0\uB294 \uAC83\uC740 \uC544\uB2C8\uBA70,
      \uC81C\uC791 \uC2DC\uAE30\uC640 \uC6A9\uB3C4, \uBB38\uD654\uC801 \uB9E5\uB77D\uC774
      \uC911\uC694\uD569\uB2C8\uB2E4."
  - showName: 1
    answerText: "\uC720\uBB3C\uC740 \uD604\uC7AC \uC0DD\uD65C\uACFC \uC544\uBB34
      \uAD00\uB828\uC774 \uC5C6\uC2B5\uB2C8\uB2E4."
    resultDescription: "\uC720\uBB3C\uC740 \uACFC\uAC70\uC758 \uC0DD\uD65C\uACFC
      \uAE30\uC220\uC744 \uBCF4\uC5EC\uC8FC\uBA70, \uD604\uC7AC\uC758 \uBB38\uD654\uC640
      \uAE30\uC220\uC774 \uC5B4\uB5BB\uAC8C \uC774\uC5B4\uC84C\uB294\uC9C0 \uC774\uD574\uD558\uB294
      \uB370 \uB3C4\uC6C0\uC744 \uC90D\uB2C8\uB2E4."
  - showName: 2
    answerText: "\uD589\uC131\uC740 \uBAA8\uB450 \uAC19\uC740 \uD06C\uAE30\uC640
      \uAC19\uC740 \uD658\uACBD\uC744 \uAC00\uC9C0\uACE0 \uC788\uC2B5\uB2C8\uB2E4."
    resultDescription: "\uD589\uC131\uB9C8\uB2E4 \uD06C\uAE30, \uB300\uAE30, \uC628\uB3C4,
      \uAD6C\uC131 \uC131\uBD84\uC774 \uB2E4\uB974\uAE30 \uB54C\uBB38\uC5D0 \uC11C\uB85C
      \uB2E4\uB978 \uD2B9\uC9D5\uC744 \uAC00\uC9D1\uB2C8\uB2E4."
  - showName: 2
    answerText: "\uD589\uC131\uC740 \uD56D\uC0C1 \uC2A4\uC2A4\uB85C \uAC15\uD55C
      \uBE5B\uC744 \uB9CC\uB4E4\uC5B4\uB0C5\uB2C8\uB2E4."
    resultDescription: "\uD589\uC131\uC740 \uBCC4\uCC98\uB7FC \uC2A4\uC2A4\uB85C
      \uBE5B\uC744 \uB0B4\uC9C0 \uC54A\uACE0, \uC8FC\uB85C \uBCC4\uC758 \uBE5B\uC744
      \uBC18\uC0AC\uD574\uC11C \uAD00\uCE21\uB429\uB2C8\uB2E4."
  - showName: 2
    answerText: "\uD589\uC131\uC758 \uC704\uCE58\uB098 \uADA4\uB3C4\uB294 \uC911\uC694\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4."
    resultDescription: "\uD589\uC131\uC758 \uADA4\uB3C4\uC640 \uC704\uCE58\uB294
      \uAE30\uD6C4, \uACF5\uC804 \uC8FC\uAE30, \uAD00\uCE21 \uBC29\uC2DD \uB4F1\uC744
      \uC774\uD574\uD558\uB294 \uB370 \uC911\uC694\uD55C \uC815\uBCF4\uC785\uB2C8\uB2E4."
  questionText: {fileID: 698409832}
  answerButtons:
  - {fileID: 70700059}
  - {fileID: 935184538}
  - {fileID: 313997812}
  resultPanel: {fileID: 508734739}
